{
    "name": "jelly-music-app",
    "private": true,
    "version": "0.4.9",
    "type": "module",
    "packageManager": "yarn@1.22.22",
    "scripts": {
        "dev": "vite",
        "dev:nocache": "vite",
        "build": "tsc -b && vite build",
        "lint": "eslint .",
        "preview": "vite preview",
        "deploy": "tsc -b && vite build && node copy404.js && gh-pages -d dist",
        "dev:desktop": "yarn tauri dev",
        "build:desktop": "yarn tauri build",
        "package:web": "bash ./scripts/web-release.sh",
        "package:desktop:linux": "bash ./scripts/desktop-linux-release.sh",
        "package:desktop:win": "powershell ./scripts/desktop-windows-release.ps1",
        "package:desktop:macos": "bash ./scripts/desktop-macos-release.sh",
        "format": "prettier --write . --ignore-path .gitignore --ignore-path src-tauri/.gitignore"
    },
    "dependencies": {
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/modifiers": "^9.0.0",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@fontsource-variable/inter": "^5.2.8",
        "@jellyfin/sdk": "^0.13.0",
        "@primer/octicons-react": "^19.21.2",
        "@tanstack/query-sync-storage-persister": "^5.90.22",
        "@tanstack/react-query": "^5.90.20",
        "@tanstack/react-query-persist-client": "^5.90.22",
        "@tauri-apps/plugin-window-state": "~2.4.1",
        "@types/m3u8-parser": "^7.2.6",
        "@types/node": "^25.0.10",
        "axios": "^1.13.2",
        "figma-squircle": "^1.1.0",
        "hls.js": "^1.6.15",
        "m3u8-parser": "^7.2.0",
        "react": "^19.2.3",
        "react-dom": "^19.2.3",
        "react-router-dom": "7.13.0",
        "react-virtuoso": "^4.18.1"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.2",
        "@tauri-apps/cli": "^2.9.6",
        "@types/react": "^19.2.9",
        "@types/react-dom": "^19.2.3",
        "@types/react-router-dom": "^5.3.3",
        "@vitejs/plugin-react": "^5.1.2",
        "eslint": "^9.39.2",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.4.26",
        "gh-pages": "^6.3.0",
        "globals": "^17.1.0",
        "prettier": "^3.8.1",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.53.1",
        "vite": "^7.3.1",
        "vite-plugin-pwa": "^1.2.0"
    }
}
